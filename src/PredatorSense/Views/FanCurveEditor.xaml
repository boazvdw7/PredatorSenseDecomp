<Window x:Class="PredatorSense.FanCurveEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fan Curve Editor" Height="450" Width="800"
        xmlns:predatorsense="clr-namespace:PredatorSense"
        Background="{DynamicResource UiWindowBackgroundBrush}"
        BorderBrush="{DynamicResource UiWindowBorderBrush}">
    <FrameworkElement.Resources>
        <ResourceDictionary>
            <Style x:Key="FanCurveDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{DynamicResource UiTitleBarBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource UiMainTextBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="BorderBrush" Value="{DynamicResource UiPanelBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </FrameworkElement.Resources>
    <Grid Background="{DynamicResource UiWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="FanCurveGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="10"
                  Grid.Column="0"
                  ItemsSource="{Binding FanCurve}"
                  Background="{DynamicResource UiPanelBackgroundBrush}"
                  Foreground="{DynamicResource UiMainTextBrush}"
                  RowBackground="{DynamicResource UiPanelBackgroundBrush}"
                  AlternatingRowBackground="{DynamicResource UiWindowBackgroundBrush}"
                  ColumnHeaderStyle="{StaticResource FanCurveDataGridColumnHeaderStyle}"
                  GridLinesVisibility="None"
                  Height="300"
                  BorderBrush="{DynamicResource UiPanelBorderBrush}"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Temperature (C)"
                                    Binding="{Binding Temperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn Header="Fan Speed (%)"
                                    Binding="{Binding FanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Column="1" Margin="10" Background="{DynamicResource UiPanelBackgroundBrush}">
            <Canvas x:Name="ChartCanvas" Background="{DynamicResource UiPanelBackgroundBrush}" />
            <TextBlock Text="Fan Speed (%)"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="5,0,0,0"
                       FontWeight="Bold"
                       Foreground="{DynamicResource UiMainTextBrush}"/>
            <TextBlock Text="Temperature (C)"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"
                       Margin="0,0,5,5"
                       FontWeight="Bold"
                       Foreground="{DynamicResource UiMainTextBrush}"/>
        </Grid>

        <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,0,60">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                   Text="Enabled: "
                   Grid.Column="0"
                   Grid.Row="0"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Left"
                   Foreground="{DynamicResource UiMainTextBrush}"
                   Margin="20,20,0,0"/>
                <CheckBox
                    x:Name="fancurvekey_Checkbox"
                    Width="120"
                    Height="20"
                    Grid.Column="1"
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Template="{DynamicResource SettingCheckBox_ControlTemplate}"
                    Checked="fancurvekey_Checkbox_Checked"
                    Unchecked="fancurvekey_Checkbox_Unchecked"/>
            </Grid>
        </Grid>

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Orientation="Horizontal" Margin="130,5,0,15" Grid.Column="0" Grid.Row="1">
            <Button Content="Add Point" Height="20" Width="80" Margin="0,0,5,0" Click="AddPoint_Click" Background="GreenYellow"/>
            <Button Content="Remove Point" Height="20" Width="100" Click="RemovePoint_Click" Background="OrangeRed"/>
        </StackPanel>

        <Button Content="Save"
                Grid.Row="1"
                Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="20,10,0,15"
                Width="100"
                Click="Save_Click"
                x:Name="SaveButton"
                Grid.ColumnSpan="2"
                Background="{DynamicResource UiButtonBackgroundBrush}"
                BorderBrush="{DynamicResource UiButtonBorderBrush}"
                Foreground="{DynamicResource UiMainTextBrush}"/>
    </Grid>
</Window>



